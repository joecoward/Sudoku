<Window x:Class="Sudoku.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sudoku.WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="470">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="TimerDisplay"
               Grid.Row = "0"
               Text="{Binding Timer.TimeDisplay}"
               FontSize="20"
               Margin="4,18,400,0"
                   />
        <TextBlock x:Name="MistacksCounter"
               Grid.Row = "0"
               Text="{Binding Mistakes.MistakeCounter}"
               FontSize="20"
               Margin="223,18,210,0"
                   />

        <ContentControl x:Name="GameControl" 
                    Grid.Row="1"
                    Height="470" 
                    Width="470"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"/>
    </Grid>
</Window>
