<Window x:Class="Sudoku.WPF.MenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sudoku.WPF"
        mc:Ignorable="d"
        Title="MenuWindow" Height="450" Width="400">
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <TextBlock FontSize="40"
                   Text="Sudoku"
                   Height="50"
                   Width="140"
                   VerticalAlignment="Top"
                   Margin="0,30"/>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock FontSize="20"
           Text="Select difficulty"
           Height="30"
           Width="140"
           VerticalAlignment="Top"
           Margin="20"
           Padding="0"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <RadioButton x:Name="RbEasy" Content="Easy" HorizontalAlignment="Left" FontSize="18" Margin="5"  Tag="Easy"/>
                <RadioButton x:Name="RbNormal" Content="Normal" HorizontalAlignment="Left" FontSize="18" Margin="5" Tag="Normal"/>
                <RadioButton x:Name="RbHard" Content="Hard" HorizontalAlignment="Left" FontSize="18" Margin="5" Tag="Hard"/>
            </StackPanel>

            <Button x:Name="Start"
                Height="30"
                Width="100"
                Content="Start"
                VerticalAlignment="Bottom"
                Margin="0,40"
                Click="StartGame_Click"
                />
        </StackPanel>


        <TextBlock Grid.Row="0"
            Text="You can register or log in"
            VerticalAlignment="Top"
            HorizontalAlignment="Center" Margin="0,320,0,0"
                   />
        
        <Button x:Name="Registration"
                Click="Registration_Click"
                Content="Registration"
                VerticalAlignment="Top"
                Width="70"
                Height="20"
                Margin="0,340,60,0"/>
        
        <Button x:Name="Login"
        Content="Login"
        VerticalAlignment="Top"
        Width="40"
        Height="20"
        Margin="90,340,0,0"/>

    </Grid>
</Window>
